{
  "name": "rsbuild-vue3-ts-starter",
  "version": "0.2.3",
  "description": "Vue3 TypeScript Starter project for Rsbuild.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "author": {
    "name": "Logue",
    "email": "logue@hotmail.co.jp",
    "url": "https://logue.dev/"
  },
  "homepage": "https://github.com/logue/rsbuild-vue3-ts-starter",
  "repository": {
    "type": "git",
    "url": "git@github.com:logue/rsbuild-vue3-ts-starter.git"
  },
  "bugs": {
    "url": "https://github.com/logue/rsbuild-vue3-ts-starter/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "rsbuild dev --open",
    "build": "run-p type-check \"build-only {@}\" --",
    "build:clean": "rimraf dist",
    "preview": "rsbuild preview",
    "skills:update": "npx skills update",
    "lint": "run-s lint:*",
    "lint:rslint": "rslint --fix .",
    "lint:biome": "biome format --write",
    "lint:prettier": "prettier \"./**/*.{yaml,css,sass,scss,htm,html,vue,md}\" -w -u",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "build-only": "rsbuild build",
    "type-check": "vue-tsc --build --force",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@rsbuild/core": "^2.1.0",
    "@rsbuild/plugin-vue": "^2.0.0",
    "@rslint/core": "^0.6.3",
    "@rstest/adapter-rsbuild": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^26.0.1",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.5",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  },
  "lint-staged": {
    "*": "run-s lint:*.{js,ts,yaml,json,css,sass,scss,htm,html,vue,md} --"
  },
  "stackblitz": {
    "startCommand": "pnpm run test:unit"
  }
}